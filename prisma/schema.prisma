generator client {
  provider = "prisma-client"
  output   = "../backend/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  USER
  MANAGER
  ADMIN
}

enum DataSource {
  MANUAL
  PERSONAL
  SWFR
  STARPLAN
  STARPLAN_ARCHIVE
  INVITATION
}

model User {
  id           Int       @id @default(autoincrement())
  name         String
  email        String    @unique
  publicKeyJson String?  @ignore
  passwordHash String
  passwordSalt String
  role         Role      @default(USER)
  sessions     Session[]
  publicKeys   UserPublicKey[]
  changeRequests ManagementChangeRequest[]
  contacts     Contact[]
  studyInfos   StudyInfo[]
  studyModules StudyModule[]
  lessons      Lesson[]
  todos        Todo[]
  lessonVisits LessonVisit[]
  lessonModulePreferences LessonModulePreference[]
  sentLessonInvitations LessonInvitation[] @relation("LessonInvitationSender")
  receivedLessonInvitations LessonInvitation[] @relation("LessonInvitationRecipient")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model UserPublicKey {
  id            Int      @id @default(autoincrement())
  userId        Int
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  publicKeyJson String
  createdAt     DateTime @default(now())

  @@unique([userId, publicKeyJson])
  @@index([userId])
}

model Session {
  id        Int      @id @default(autoincrement())
  tokenHash String   @unique
  activeRole Role
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([userId])
  @@index([expiresAt])
}

model PendingAccount {
  id                    Int      @id @default(autoincrement())
  name                  String
  email                 String   @unique
  publicKeyJson         String?
  passwordHash          String
  passwordSalt          String
  role                  Role     @default(USER)
  confirmationTokenHash String   @unique
  requestedById         Int?
  createdAt             DateTime @default(now())
  expiresAt             DateTime

  @@index([expiresAt])
}

enum ChangeAction {
  CREATE
  UPDATE
  DELETE
}

enum ChangeEntity {
  CONTACT
  DEADLINE
  MEAL
  LESSON
  STUDY_INFO
}

enum ChangeStatus {
  PENDING
  APPROVED
  REJECTED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model ManagementChangeRequest {
  id          Int          @id @default(autoincrement())
  action      ChangeAction
  entity      ChangeEntity
  targetId    Int?
  payloadJson String
  status      ChangeStatus @default(PENDING)
  requestedById Int
  requestedBy   User       @relation(fields: [requestedById], references: [id], onDelete: Cascade)
  reviewedById Int?
  reviewedAt   DateTime?
  reviewNote   String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([requestedById])
  @@index([status])
  @@index([entity, targetId])
}

model Contact {
  id        Int      @id @default(autoincrement())
  ownerId   Int?
  owner     User?    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name      String
  role      String
  email     String
  phone     String?
  room      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
}

model Canteen {
  id        Int        @id @default(autoincrement())
  name      String
  location  String?
  meals     MealPlan[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model MealPlan {
  id             Int      @id @default(autoincrement())
  canteenId      Int
  canteen        Canteen  @relation(fields: [canteenId], references: [id], onDelete: Cascade)
  day            String
  date           DateTime?
  mainDish       String
  vegetarianDish String?
  priceCents     Int
  currency       String   @default("EUR")
  isPersonal     Boolean  @default(false)
  source         DataSource @default(MANUAL)
  sourceKey      String?  @unique
  importedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([canteenId])
  @@index([date])
  @@index([source])
}

model Deadline {
  id          Int      @id @default(autoincrement())
  title       String
  date        DateTime
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
}

model Todo {
  id          Int           @id @default(autoincrement())
  ownerId     Int
  owner       User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  title       String
  description String?
  completedAt DateTime?
  subtasks    TodoSubtask[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([ownerId])
  @@index([completedAt])
}

model TodoSubtask {
  id          Int       @id @default(autoincrement())
  todoId      Int
  todo        Todo      @relation(fields: [todoId], references: [id], onDelete: Cascade)
  title       String
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([todoId])
}

model StudyInfo {
  id        Int      @id @default(autoincrement())
  ownerId   Int?
  owner     User?    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  category  String
  title     String
  content   String
  encryptedPayload String?
  encryptedKey String?
  encryptionIv String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@index([category, sortOrder])
}

model StudyModule {
  id        Int      @id @default(autoincrement())
  ownerId   Int?
  owner     User?    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  title     String
  credits   String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@map("Module")
}

model ScheduleDay {
  id        Int      @id @default(autoincrement())
  day       String   @unique
  sortOrder Int      @default(0)
  lessons   Lesson[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lesson {
  id            Int         @id @default(autoincrement())
  ownerId       Int?
  owner         User?       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  scheduleDayId Int
  scheduleDay   ScheduleDay @relation(fields: [scheduleDayId], references: [id], onDelete: Cascade)
  date          DateTime?
  startTime     String
  endTime       String
  title         String
  description   String?
  encryptedPayload String?
  encryptedKey     String?
  encryptionIv     String?
  isRecurring   Boolean     @default(false)
  room          String?
  lecturer      String?
  source        DataSource  @default(MANUAL)
  sourceKey     String?     @unique
  importedAt    DateTime?
  invitations   LessonInvitation[]
  visits         LessonVisit[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([ownerId])
  @@index([date])
  @@index([source])
  @@index([ownerId, date])
  @@index([scheduleDayId])
}

model LessonVisit {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId  Int
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  date      DateTime
  visitedAt DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, lessonId, date])
  @@index([lessonId])
  @@index([userId])
}

model LessonModulePreference {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  moduleKey String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, moduleKey])
  @@index([userId])
}

model LessonInvitation {
  id          Int              @id @default(autoincrement())
  lessonId    Int
  lesson      Lesson           @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  senderId    Int
  sender      User             @relation("LessonInvitationSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipientId Int
  recipient   User             @relation("LessonInvitationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  status      InvitationStatus @default(PENDING)
  encryptedPayload String?
  encryptedKey     String?
  encryptionIv     String?
  respondedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([lessonId, recipientId])
  @@index([recipientId])
  @@index([senderId])
  @@index([status])
}

model ScheduleImportCache {
  id           Int      @id @default(autoincrement())
  cacheKey     String   @unique
  facultyId    String
  facultyName  String
  studyGroup   String
  semesterId   String
  semesterName String
  specialization String?
  weekStart    DateTime
  payloadJson  String
  importedAt   DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([weekStart])
  @@index([importedAt])
}

enum CurriculumDocumentType {
  SPO_GENERAL
  SPO_SPECIAL
  MODULE_CATALOG
}

enum CurriculumModuleArea {
  BASIC
  ADVANCED
  SPECIALIZATION
  INTERNSHIP
  THESIS
}

enum CurriculumRecordStatus {
  RAW
  PARSED
  NORMALIZED
  NEEDS_REVIEW
  VALIDATED
}

enum CurriculumAssessmentCategory {
  COURSEWORK
  EXAM
}

enum ElectiveSlotKind {
  FACULTY_CATALOG
  FREE_CHOICE
}

model CurriculumDocument {
  id         String                @id
  type       CurriculumDocumentType
  programCode String
  title      String
  versionLabel String?
  effectiveDate DateTime?
  retrievedAt DateTime?
  fileName   String
  filePath   String?
  sha256     String
  pageCount  Int
  sourceRefs CurriculumSourceRef[]
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @default(now()) @updatedAt

  @@index([programCode, type])
}

model StudyProgram {
  id                    String                    @id
  code                  String                    @unique
  name                  String
  degree                String
  totalCredits          Int
  regularSemesters      Int
  basicStudySemesters   Int
  advancedStudySemesters Int
  bilingual             Boolean                   @default(false)
  semesters             ProgramSemester[]
  modules               CurriculumModule[]
  specializations       Specialization[]
  electiveSlots         ElectiveSlot[]
  sourceRefs            CurriculumSourceRef[]
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @default(now()) @updatedAt
}

model ProgramSemester {
  id            Int                @id @default(autoincrement())
  studyProgramId String
  studyProgram  StudyProgram       @relation(fields: [studyProgramId], references: [id], onDelete: Cascade)
  number        Int
  title         String
  credits       Int
  area          String
  modules       CurriculumModule[]
  electiveSlots ElectiveSlot[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @default(now()) @updatedAt

  @@unique([studyProgramId, number])
}

model CurriculumModule {
  id                String                             @id
  studyProgramId    String
  studyProgram      StudyProgram                       @relation(fields: [studyProgramId], references: [id], onDelete: Cascade)
  semesterId        Int?
  semester          ProgramSemester?                   @relation(fields: [semesterId], references: [id], onDelete: SetNull)
  title             String
  credits           Int
  area              CurriculumModuleArea
  status            CurriculumRecordStatus             @default(VALIDATED)
  language          String?
  workloadHours     Int?
  contactHours      Int?
  selfStudyHours    Int?
  frequency         String?
  duration          String?
  prerequisitesText String?
  sortOrder         Int                                @default(0)
  courses           CurriculumCourse[]
  assessments       CurriculumAssessment[]
  prerequisiteModules CurriculumModulePrerequisite[]   @relation("CurriculumModulePrerequisiteSource")
  requiredByModules   CurriculumModulePrerequisite[]   @relation("CurriculumModulePrerequisiteTarget")
  tags                CurriculumModuleTag[]
  specializations     CurriculumModuleSpecialization[]
  candidateInElectiveSlots ElectiveSlotCandidateModule[]
  sourceRefs          CurriculumSourceRef[]
  createdAt         DateTime                           @default(now())
  updatedAt         DateTime                           @default(now()) @updatedAt

  @@index([studyProgramId, semesterId, sortOrder])
  @@index([title])
  @@index([area])
}

model CurriculumCourse {
  id         Int              @id @default(autoincrement())
  moduleId   String
  module     CurriculumModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title      String
  kindCode   String
  kindLabel  String
  weeklyHours Int?
  sortOrder  Int              @default(0)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @default(now()) @updatedAt

  @@index([moduleId, sortOrder])
}

model CurriculumAssessment {
  id          Int                          @id @default(autoincrement())
  moduleId    String
  module      CurriculumModule             @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  category    CurriculumAssessmentCategory
  code        String
  label       String
  credits     Int?
  description String?
  sortOrder   Int                          @default(0)
  createdAt   DateTime                     @default(now())
  updatedAt   DateTime                     @default(now()) @updatedAt

  @@index([moduleId, sortOrder])
  @@index([category, code])
}

model CurriculumModulePrerequisite {
  sourceModuleId String
  sourceModule   CurriculumModule @relation("CurriculumModulePrerequisiteSource", fields: [sourceModuleId], references: [id], onDelete: Cascade)
  targetModuleId String
  targetModule   CurriculumModule @relation("CurriculumModulePrerequisiteTarget", fields: [targetModuleId], references: [id], onDelete: Cascade)

  @@id([sourceModuleId, targetModuleId])
  @@index([targetModuleId])
}

model Specialization {
  id            String                         @id
  studyProgramId String
  studyProgram  StudyProgram                   @relation(fields: [studyProgramId], references: [id], onDelete: Cascade)
  code          String
  name          String
  description   String?
  modules       CurriculumModuleSpecialization[]
  createdAt     DateTime                       @default(now())
  updatedAt     DateTime                       @default(now()) @updatedAt

  @@unique([studyProgramId, code])
}

model CurriculumTag {
  id        String                @id
  label     String
  category  String
  modules   CurriculumModuleTag[]
  createdAt DateTime              @default(now())
  updatedAt DateTime              @default(now()) @updatedAt

  @@index([category])
}

model CurriculumModuleTag {
  moduleId String
  module   CurriculumModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  tagId    String
  tag      CurriculumTag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([moduleId, tagId])
  @@index([tagId])
}

model CurriculumModuleSpecialization {
  moduleId         String
  module           CurriculumModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  specializationId String
  specialization   Specialization   @relation(fields: [specializationId], references: [id], onDelete: Cascade)

  @@id([moduleId, specializationId])
  @@index([specializationId])
}

model ElectiveSlot {
  id            String                         @id
  studyProgramId String
  studyProgram  StudyProgram                   @relation(fields: [studyProgramId], references: [id], onDelete: Cascade)
  semesterId    Int
  semester      ProgramSemester                @relation(fields: [semesterId], references: [id], onDelete: Cascade)
  name          String
  credits       Int
  kind          ElectiveSlotKind
  status        CurriculumRecordStatus         @default(VALIDATED)
  description   String?
  sortOrder     Int                            @default(0)
  candidateModules ElectiveSlotCandidateModule[]
  sourceRefs       CurriculumSourceRef[]
  createdAt     DateTime                       @default(now())
  updatedAt     DateTime                       @default(now()) @updatedAt

  @@index([studyProgramId, semesterId, sortOrder])
}

model ElectiveSlotCandidateModule {
  electiveSlotId String
  electiveSlot   ElectiveSlot      @relation(fields: [electiveSlotId], references: [id], onDelete: Cascade)
  moduleId       String
  module         CurriculumModule  @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@id([electiveSlotId, moduleId])
  @@index([moduleId])
}

model CurriculumSourceRef {
  id             Int                 @id @default(autoincrement())
  documentId     String
  document       CurriculumDocument  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  studyProgramId String?
  studyProgram   StudyProgram?       @relation(fields: [studyProgramId], references: [id], onDelete: Cascade)
  moduleId       String?
  module         CurriculumModule?   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  electiveSlotId String?
  electiveSlot   ElectiveSlot?       @relation(fields: [electiveSlotId], references: [id], onDelete: Cascade)
  pageStart      Int
  pageEnd        Int
  locator        String?
  note           String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @default(now()) @updatedAt

  @@index([documentId, pageStart, pageEnd])
  @@index([studyProgramId])
  @@index([moduleId])
  @@index([electiveSlotId])
}
