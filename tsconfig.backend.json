{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "customConditions": [
      "node"
    ],
    "lib": [
      "esnext"
    ],
    "module": "preserve",
    "moduleResolution": "bundler",
    "noEmit": true
  },
  "include": [
    "backend/src/**/*.ts",
    "backend/generated/prisma/**/*.ts",
    "prisma/**/*.ts",
    "prisma.config.ts"
  ]
}
