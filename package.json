{
  "name": "studentgo",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "postinstall": "node ./scripts/patch-react-native-gradle-plugin.js",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web --output-dir dist",
    "build:backend": "tsc --noEmit -p tsconfig.backend.json",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit --pretty false",
    "test": "node --import tsx --test backend/test/*.test.ts",
    "test:unit": "node --import tsx --test backend/test/auth-service.test.ts backend/test/security.test.ts",
    "test:integration": "node --import tsx --test backend/test/integration.test.ts",
    "backend:dev": "tsx watch backend/src/server.ts",
    "backend:start": "tsx backend/src/server.ts",
    "backend:start:prod": "prisma migrate deploy && node --import tsx backend/src/server.ts",
    "db:generate": "prisma generate",
    "db:deploy": "prisma migrate deploy",
    "db:adopt-main": "node ./scripts/adopt-main-prisma-db.js",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "expo": "^55.0.17",
    "expo-build-properties": "~55.0.14",
    "expo-camera": "~55.0.19",
    "expo-constants": "^55.0.15",
    "expo-file-system": "~55.0.17",
    "expo-font": "~55.0.6",
    "expo-haptics": "~55.0.14",
    "expo-image": "~55.0.11",
    "expo-linking": "~55.0.15",
    "expo-router": "~55.0.16",
    "expo-secure-store": "~55.0.14",
    "expo-splash-screen": "^55.0.19",
    "expo-status-bar": "~55.0.6",
    "expo-symbols": "~55.0.9",
    "expo-system-ui": "~55.0.18",
    "expo-web-browser": "~55.0.16",
    "express": "^5.2.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-get-random-values": "~1.11.0",
    "react-native-nfc-manager": "^3.17.2",
    "react-native-nitro-modules": "^0.35.6",
    "react-native-quick-base64": "^2.2.2",
    "react-native-quick-crypto": "^1.1.1",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.4",
    "prisma": "^7.8.0",
    "toqr": "^0.1.1",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/react": "~19.2.10",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~55.0.1",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "@prisma/dev": {
      "@hono/node-server": "1.19.13"
    },
    "js-yaml": "4.2.0",
    "xcode": {
      "uuid": "11.1.1"
    }
  },
  "private": true
}
